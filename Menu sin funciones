#include <iostream>
using namespace std;

int main()
{
	int opcion,base,altura, n1, n2, n3,nm,nt=0,p,n,t,i;
	do {
		cout<<"\nMENU"<<endl;
		cout<<"1. Calcular area del triangulo"<<endl;
		cout<<"2.Encontrar el mayor de 3 numeros"<<endl;
		cout<<"3.Encontrar el promedio de N numeros"<<endl;
		cout<<"0. Salir"<<endl;
		cout<<"Ingresar la opcion: ";
		cin>>opcion;
		switch(opcion) {
		case 1:
			cout<<"Ingrese la base: ";
			cin>>base;
			cout<<"ingre la altura: ";
			cin>>altura;
			cout<<"El area del triangulo es: "<<base*altura/2.0;
			break;
		case 2:
			cout<<"Ingrese 3 numeros"<<endl;
			cin>>n1;
			cin>>n2;
			cin>>n3;
			if(n1>n2&&n1>n3)
				cout<<"El numero mayor es: "<<n1;
			else if(n2>n1&&n2>n3)
				cout<<"El numero mayor es:"<<n2;
			else
				cout<<"El numero mayor es:"<<n3;
			break;
		case 3:
			cout<<"Ingrese la cantidade numeros"<<endl;
			cin>>t;
			for(i=0; i<t; i=i+1) {
				cout<<"Ingrese un numero"<<endl;
				cin>>n;
				nt=nt+n;
			}
			p=nt/t;
			cout<<"El promedio es: "<<p;
			break;
		case 0:
			cout<<"Salir"<<endl;
			break;
		default:
			cout<<"Error"<<endl;
			break;

		}
	} while(opcion!=0);
}
