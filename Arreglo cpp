#include <iostream>
#include "Arreglo.h"

using namespace std;

Arreglo::Arreglo(void)
{
	vec[10] = 0;
	n = 0;
}


Arreglo::~Arreglo(void)
{
}

void Arreglo::cargarVector(int vec[], int n) {
	for (int i = 0; i < n; i++) {
		cout << "vec[" << i << "] =";
		cin >> vec[i];
	}
}

void Arreglo::mostrarVector(int vec[], int n) {
	for (int i = 0; i < n; i++) {
		cout << vec[i] << ", ";
	}
	cout << endl;
}

void Arreglo::ordenarVector(int vec[], int n) {
	int aux;
	for (int i = 0; i < (n - 1); i++) {
		for (int j = i; j < n; j++) {
			if (vec[i] > vec[j]) {
				aux = vec[i];
				vec[i] = vec[j];
				vec[j] = aux;
			}
		}
	}
}
